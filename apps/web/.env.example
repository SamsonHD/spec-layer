# Markdown content root. Absolute, relative to apps/web, or ~-prefixed.
# Defaults to apps/web/content/components.
# DS_CONTENT_DIR=~/work/my-design-system/components

# Shared bearer token for cross-origin local API clients such as the Figma
# plugin. Generate a random value, for example: openssl rand -hex 32
SPEC_LAYER_TOKEN=

# Optional comma-separated additions to the loopback Host allowlist.
# Include the port when the Host header includes one.
# SPEC_LAYER_ALLOWED_HOSTS=docs.internal.example:3000

# Optional comma-separated cross-origin allowlist. Every cross-origin request
# still requires SPEC_LAYER_TOKEN. Origin: null is supported for the Figma plugin.
# SPEC_LAYER_ALLOWED_ORIGINS=https://docs.internal.example

# Optional Figma personal access token for live preview images.
FIGMA_TOKEN=

# Optional Anthropic API key for prose generation during import/regeneration.
ANTHROPIC_API_KEY=
