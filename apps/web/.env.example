# Path to your design system's markdown specs. Absolute, relative-to-project,
# or ~-prefixed. Defaults to the bundled ./content/components if unset.
# DS_CONTENT_DIR=~/work/my-design-system/components

# Figma personal access token — enables live component preview images.
# Create one at: https://www.figma.com/developers/api#access-tokens
# Without it, the app still works; preview hero shows a "set FIGMA_TOKEN" note.
FIGMA_TOKEN=
